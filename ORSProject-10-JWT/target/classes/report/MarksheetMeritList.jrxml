	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Project10DataAdapter.xml"/>
	<queryString language="SQL">
		<![CDATA[select 
  roll_no, 
  name, 
  physics, 
  chemistry, 
  maths,
  (physics + chemistry + maths) as total,
  round(cast((physics + chemistry + maths) as double) / 3, 2) as percentage
from st_marksheet
where physics > 33 
and chemistry > 33 
and maths > 33]]>
	</queryString>
